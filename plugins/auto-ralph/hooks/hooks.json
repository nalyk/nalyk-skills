{
  "description": "SessionStart emits a one-line notice; UserPromptSubmit flags imperative verbs / explicit triggers and stays silent otherwise.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/sessionstart.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/userpromptsubmit.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
